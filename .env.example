DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

POSTGRES_DB=dde_affectation_extranet
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# PV OTP email delivery (use your organisation's SMTP account in .env)
EMAIL_HOST=smtp.example.gov.ma
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=pv-otp@example.gov.ma
EMAIL_HOST_PASSWORD=change-me
DEFAULT_FROM_EMAIL=pv-otp@example.gov.ma
EMAIL_TIMEOUT=15
PV_OTP_EXPIRY_MINUTES=10
PV_OTP_MAX_ATTEMPTS=3
PV_OTP_REQUEST_COOLDOWN_SECONDS=60

# Development only. Never enable this in production.
PV_PRINT_OTP_TO_CONSOLE=False
